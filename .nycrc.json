{
  "reporter": ["text", "html", "lcov"],
  "report-dir": "./coverage",
  "exclude": [
    "node_modules",
    "test",
    "coverage",
    "public",
    ".github"
  ],
  "include": [
    "server.js",
    "database.js",
    "middleware/**/*.js",
    "routes/**/*.js",
    "auth.js"
  ],
  "all": true,
  "lines": 70,
  "statements": 70,
  "functions": 70,
  "branches": 60
}
