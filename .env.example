# Google OAuth — https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# OAuth callback — must match what's registered in Google Console
CALLBACK_URL=http://localhost:3000/auth/google/callback

# Session — any long random string (e.g. openssl rand -hex 32)
SESSION_SECRET=change-me-long-random-string

# Optional — defaults to 3000
PORT=3000
