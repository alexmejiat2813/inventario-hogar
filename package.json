{
  "name": "inventario-hogar",
  "version": "1.1.2",
  "description": "Gestión de inventario doméstico",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js | pino-pretty",
    "test": "node --test test/*.test.js",
    "coverage": "c8 node --test test/*.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,css,html}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{js,json,css,html}\" --ignore-path .prettierignore",
    "prepare": "node -e \"try{require('child_process').execSync('git config core.hooksPath .githooks')}catch{}\""
  },
  "dependencies": {
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.4"
  }
}
